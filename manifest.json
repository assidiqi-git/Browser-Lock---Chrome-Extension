{
  "manifest_version": 3,
  "name": "Browser Lock",
  "version": "1.0",
  "description": "Prompts for a password when you open the browser.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Browser Lock Settings",
    "default_popup": "options.html",
    "default_icon": {
      "16": "images/favicon-16x16.png",
      "32": "images/favicon-32x32.png",
      "192": "images/android-chrome-192x192.png"
    }
  },
  "icons": {
    "16": "images/favicon-16x16.png",
    "32": "images/favicon-32x32.png",
    "192": "images/android-chrome-192x192.png"
  }
}
